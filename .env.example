# MongoDB
MONGODB_URI=mongodb://localhost:27017/way-esports
# MONGO_URI= (alternative name supported)

# Redis (cache + queues)
REDIS_URL=redis://localhost:6379
# Set true to run backend without Redis in local/dev environments
REDIS_DISABLED=true

# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
VITE_API_URL=/api
VITE_API_TIMEOUT_MS=30000

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_me

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=
API_BASE_URL=https://wayesports.duckdns.org
WEBAPP_URL=https://wayesports.duckdns.org
BOT_USE_WEBHOOK=false
BOT_WEBHOOK_PUBLIC_URL=https://wayesports.duckdns.org
BOT_WEBHOOK_PATH=/telegram/webhook
BOT_WEBHOOK_SECRET=
BOT_POLL_TIMEOUT_SEC=30
BOOTSTRAP_ADMIN_TELEGRAM_ID=your_telegram_id
BOOTSTRAP_ADMIN_EMAIL=
PRIMARY_ADMIN_ONLY=false

# OAuth (optional)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=

# Monitoring / metrics
METRICS_API_KEY=
ALERT_ERROR_RATE_PERCENT=5
ALERT_EVENT_LOOP_LAG_MS=300
MONITORING_INTERVAL_MS=60000

# Backups
DB_BACKUP_DIR=./backups
DB_BACKUP_RETENTION_DAYS=7

# Email Service
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PLAYER_MONTHLY=price_player_monthly
STRIPE_PRICE_PLAYER_YEARLY=price_player_yearly
STRIPE_PRICE_TEAM_MONTHLY=price_team_monthly
STRIPE_PRICE_TEAM_YEARLY=price_team_yearly
VITE_STRIPE_PRICE_PLAYER_MONTHLY=price_player_monthly
VITE_STRIPE_PRICE_PLAYER_YEARLY=price_player_yearly
VITE_STRIPE_PRICE_TEAM_MONTHLY=price_team_monthly
VITE_STRIPE_PRICE_TEAM_YEARLY=price_team_yearly

# Manual subscription payment (USDT TRC20)
SUBSCRIPTION_USDT_TRC20_ADDRESS=TAoLXyWNAZoxYCkYu4iEuk6N6jUhhDyXHU
VITE_SUBSCRIPTION_USDT_TRC20_ADDRESS=TAoLXyWNAZoxYCkYu4iEuk6N6jUhhDyXHU

# AI scouting provider (gemini | openai | none)
AI_SCOUT_PROVIDER=gemini
SUPPORT_AI_PROVIDER=gemini
SUPPORT_AI_ENABLED_DEFAULT=true
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_SCOUT_MODEL=gpt-4o-mini
OPENAI_SUPPORT_MODEL=gpt-4o-mini
HALL_OF_FAME_CRON_TOKEN=
RATE_LIMIT_API_MAX=1200
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=40
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_CREATE_ACCOUNT_MAX=15
RATE_LIMIT_CREATE_ACCOUNT_WINDOW_MS=60000
RATE_LIMIT_ANALYTICS_READ_MAX=120
RATE_LIMIT_ANALYTICS_READ_WINDOW_MS=60000
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_OPEN_MS=120000
SLOW_REQUEST_LOG_MS=1200
ADMIN_OVERVIEW_CACHE_MS=10000
MATCHES_ADMIN_CACHE_MS=5000

# Telegram bot internal integration
BOT_INTERNAL_TOKEN=
BOT_REMINDER_CHECK_MINUTES=60
BOT_REMINDER_INTERVAL_DAYS=5
BOT_VIRAL_TARGET=10
BOT_VIRAL_REWARD_FREE_ENTRIES=3
BOT_USERNAME=
